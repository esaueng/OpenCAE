{
  "name": "opencae",
  "version": "0.1.0",
  "private": true,
  "description": "OpenCAE local CAD/CAE simulation MVP scaffold.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,blue \"pnpm --filter @opencae/api dev\" \"pnpm --filter @opencae/web dev\"",
    "build": "pnpm --filter @opencae/api build && pnpm --filter @opencae/web build",
    "build:cloudflare": "pnpm --filter @opencae/web build",
    "deploy:cloudflare": "pnpm build:cloudflare && wrangler deploy --config wrangler.jsonc",
    "deploy:cloudflare:dry-run": "pnpm build:cloudflare && wrangler deploy --config wrangler.jsonc --dry-run",
    "containers:build": "wrangler containers build services/opencae-fea-container -t opencae-fea:latest",
    "containers:push": "wrangler containers push opencae-fea:latest",
    "test": "vitest run",
    "db:migrate": "pnpm --filter @opencae/db migrate",
    "db:seed": "pnpm --filter @opencae/db seed",
    "reset:local": "pnpm --filter @opencae/db reset && pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "wrangler": "^4.85.0"
  },
  "packageManager": "pnpm@9.15.4",
  "license": "Apache-2.0"
}
