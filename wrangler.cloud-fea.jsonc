{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "opencae-cloud-fea",
  "main": "apps/opencae-web/worker/index.ts",
  "compatibility_date": "2026-04-27",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "apps/opencae-web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/health"]
  },
  "r2_buckets": [
    {
      "binding": "FEA_ARTIFACTS",
      "bucket_name": "opencae-fea-artifacts"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "FEA_RUN_QUEUE",
        "queue": "opencae-fea-runs"
      }
    ],
    "consumers": [
      {
        "queue": "opencae-fea-runs",
        "max_batch_size": 1,
        "max_retries": 3,
        "dead_letter_queue": "opencae-fea-runs-dlq"
      }
    ]
  },
  "containers": [
    {
      "class_name": "OpenCaeFeaContainer",
      "image": "./services/opencae-fea-container/Dockerfile",
      "max_instances": 2
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "FEA_CONTAINER",
        "class_name": "OpenCaeFeaContainer"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["OpenCaeFeaContainer"]
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
