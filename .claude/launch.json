{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "opencae-web",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "pnpm --filter @opencae/web dev --port ${PORT:-5173}"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "opencae-web-cloud",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "OPENCAE_CLOUD_PROXY_TARGET=https://cae.esau.app pnpm --filter @opencae/web dev"],
      "port": 5173
    }
  ]
}
